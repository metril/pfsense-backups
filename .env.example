# pfSense Backup — environment template. Copy to .env and fill in.

# Worker service
# Optional: appears as "Host: <value>" in notification bodies. Leave unset
# to omit the line entirely.
#PFSENSE_BACKUPS_HOSTNAME=my-backup-box
TZ=America/Los_Angeles
LOG_LEVEL=INFO

# Web service — OIDC + session
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SESSION_SECRET=CHANGE_ME

OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=pfsense-backups
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_REDIRECT_URL=https://pfsense-backups.example.com/api/auth/callback
OIDC_ALLOWED_EMAILS=you@example.com,admin@example.com

# Traefik
WEB_HOST=pfsense-backups.example.com

# X-Forwarded-* trust list. ``*`` (the default in compose.yaml) is
# correct for the bundled Traefik topology: the web service only ever
# sees connections from the bridge gateway, so every upstream IP on
# that network is legitimate. If you expose the container port directly
# (no Traefik), TIGHTEN this to ``127.0.0.1,::1`` (or the specific
# reverse-proxy IP) — leaving it at ``*`` lets any client spoof
# ``X-Forwarded-For`` and defeat rate-limiting + audit-log client IPs.
#TRUSTED_PROXIES=127.0.0.1,::1

# Production image tag override. Used by compose.prod.yaml to pin a
# specific release. Leave unset to track ``latest``.
#IMAGE_TAG=v0.33.0
