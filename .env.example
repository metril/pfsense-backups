# pfSense Backup — environment template. Copy to .env and fill in.

# Worker service
HOSTNAME=Ouranos
TZ=America/Los_Angeles
LOG_LEVEL=INFO

# Web service — OIDC + session
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SESSION_SECRET=CHANGE_ME

OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=pfsense-backups
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_REDIRECT_URL=https://pfsense-backups.example.com/api/auth/callback
OIDC_ALLOWED_EMAILS=you@example.com,admin@example.com

# Traefik
WEB_HOST=pfsense-backups.example.com
