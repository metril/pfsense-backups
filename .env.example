# pfSense Backup — environment template. Copy to .env and fill in.

# Worker service
HOSTNAME=Ouranos
TZ=America/Los_Angeles
LOG_LEVEL=INFO

# Web service (added in a later phase) — OIDC + session
# SESSION_SECRET=<generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'>
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=pfsense-backup
# OIDC_CLIENT_SECRET=<your client secret>
# OIDC_REDIRECT_URL=https://pfsense-backup.example.com/api/auth/callback
# OIDC_ALLOWED_EMAILS=you@example.com,admin@example.com
