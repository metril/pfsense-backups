# pfSense Backup Environment Variables
# Copy this file to .env and fill in your credentials

# Main Firewall Credentials
PFSENSE_MAIN_FIREWALL_USERNAME=admin
PFSENSE_MAIN_FIREWALL_PASSWORD=your_secure_password_here

# Guest Firewall Credentials  
PFSENSE_GUEST_FIREWALL_USERNAME=admin
PFSENSE_GUEST_FIREWALL_PASSWORD=your_secure_password_here

# Add more instances as needed:
# PFSENSE_INSTANCE_NAME_USERNAME=admin
# PFSENSE_INSTANCE_NAME_PASSWORD=password