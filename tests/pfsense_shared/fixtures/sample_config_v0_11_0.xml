<?xml version="1.0"?>
<pfsense>
  <version>21.9</version>
  <revision>
    <time>1712345678</time>
    <description>initial</description>
    <username>admin@127.0.0.1</username>
  </revision>
  <system>
    <hostname>gw</hostname>
    <domain>lan.example</domain>
    <timezone>UTC</timezone>
    <timeservers>0.pool.ntp.org 1.pool.ntp.org</timeservers>
    <dnsserver>1.1.1.1</dnsserver>
    <dnsserver>9.9.9.9</dnsserver>
    <dnsallowoverride/>
    <webgui>
      <protocol>https</protocol>
      <port>443</port>
      <ssl-certref>abc123</ssl-certref>
    </webgui>
    <ssh>
      <port>22</port>
    </ssh>
    <user>
      <name>admin</name>
      <uid>0</uid>
      <scope>system</scope>
      <bcrypt-hash>$2b$10$SECRETHASH</bcrypt-hash>
      <groupname>admins</groupname>
      <cert>cert-refid-1</cert>
    </user>
    <user>
      <name>alice</name>
      <uid>2000</uid>
      <scope>user</scope>
      <bcrypt-hash>$2b$10$ALICESECRET</bcrypt-hash>
      <groupname>ops</groupname>
    </user>
    <group>
      <name>admins</name>
      <gid>1999</gid>
      <scope>system</scope>
      <priv>page-all</priv>
      <member>0</member>
    </group>
    <group>
      <name>ops</name>
      <gid>2000</gid>
      <scope>user</scope>
      <priv>page-dashboard-all</priv>
      <member>2000</member>
    </group>
    <authserver>
      <name>corp-ldap</name>
      <type>ldap</type>
      <host>ldap.lan.example</host>
      <ldap_port>636</ldap_port>
      <ldap_bindpw>supersecret</ldap_bindpw>
      <ldap_binddn>cn=bind,dc=lan,dc=example</ldap_binddn>
      <ldap_basedn>dc=lan,dc=example</ldap_basedn>
    </authserver>
  </system>
  <sysctl>
    <item>
      <tunable>net.inet.ip.random_id</tunable>
      <value>1</value>
      <descr>randomize IP ids</descr>
    </item>
  </sysctl>
  <cron>
    <item>
      <minute>1</minute>
      <hour>*</hour>
      <mday>*</mday>
      <month>*</month>
      <wday>*</wday>
      <who>root</who>
      <command>/usr/bin/nice -n 20 /etc/rc.filter_configure</command>
    </item>
  </cron>
  <interfaces>
    <wan>
      <if>em0</if>
      <enable/>
      <ipaddr>dhcp</ipaddr>
      <descr>WAN</descr>
      <blockpriv/>
      <blockbogons/>
    </wan>
    <lan>
      <if>em1</if>
      <enable/>
      <ipaddr>192.168.1.1</ipaddr>
      <subnet>24</subnet>
      <descr>LAN</descr>
    </lan>
    <opt1>
      <if>em2</if>
      <enable/>
      <ipaddr>10.10.0.1</ipaddr>
      <subnet>24</subnet>
      <descr>DMZ</descr>
    </opt1>
  </interfaces>
  <gateways>
    <gateway_item>
      <name>WAN_DHCP</name>
      <interface>wan</interface>
      <gateway>dynamic</gateway>
      <ipprotocol>inet</ipprotocol>
      <defaultgw/>
    </gateway_item>
  </gateways>
  <staticroutes>
    <route>
      <network>192.168.99.0/24</network>
      <gateway>WAN_DHCP</gateway>
      <descr>remote lab</descr>
    </route>
  </staticroutes>
  <filter>
    <rule>
      <tracker>1699999001</tracker>
      <type>pass</type>
      <interface>lan</interface>
      <protocol>tcp</protocol>
      <source><network>lan</network></source>
      <destination><any/></destination>
      <descr>allow lan out</descr>
    </rule>
    <rule>
      <tracker>1699999002</tracker>
      <type>block</type>
      <interface>wan</interface>
      <source><any/></source>
      <destination><any/></destination>
      <descr>default deny</descr>
      <log/>
    </rule>
  </filter>
  <nat>
    <rule>
      <interface>wan</interface>
      <protocol>tcp</protocol>
      <source><any/></source>
      <destination><address>wanip</address><port>443</port></destination>
      <target>192.168.1.10</target>
      <local-port>443</local-port>
      <descr>web server</descr>
    </rule>
    <outbound>
      <rule>
        <interface>wan</interface>
        <source><network>192.168.1.0/24</network></source>
        <target>wanip</target>
        <descr>LAN out</descr>
      </rule>
    </outbound>
  </nat>
  <aliases>
    <alias>
      <name>WEB_PORTS</name>
      <type>port</type>
      <address>80 443 8443</address>
      <detail>http||https||alt</detail>
    </alias>
    <alias>
      <name>MGMT_HOSTS</name>
      <type>host</type>
      <address>192.168.1.5 192.168.1.6</address>
    </alias>
  </aliases>
  <dhcpd>
    <lan>
      <enable/>
      <range>
        <from>192.168.1.100</from>
        <to>192.168.1.200</to>
      </range>
      <domain>lan.example</domain>
      <dnsserver>192.168.1.1</dnsserver>
      <staticmap>
        <mac>00:11:22:33:44:55</mac>
        <ipaddr>192.168.1.50</ipaddr>
        <hostname>printer</hostname>
      </staticmap>
    </lan>
  </dhcpd>
  <unbound>
    <enable/>
    <port>53</port>
    <hosts>
      <host>app</host>
      <domain>lan.example</domain>
      <ip>192.168.1.10</ip>
      <descr>app server</descr>
    </hosts>
    <domainoverrides>
      <domain>corp.internal</domain>
      <ip>10.0.0.1</ip>
      <descr>corp DNS</descr>
    </domainoverrides>
  </unbound>
  <widgets>
    <dashboard>ignored</dashboard>
  </widgets>
  <!-- A section we don't parse in v0.11.0 -->
  <hasync>
    <pfsyncenabled>on</pfsyncenabled>
  </hasync>
</pfsense>
